{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023", "DOM"],
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": ["src/**/*.js", "src/**/*.d.ts", "cli/**/*.js", "bin/**/*.js", "components/**/*.d.ts"],
  "exclude": ["node_modules", "fixtures", "**/*.test.js", "**/*.test.ts", "**/*.astro"]
}
